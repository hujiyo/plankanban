<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 浅色：参考 Win11 Fluent，更柔和的中性色 + 半透明 -->

    <!-- Color 资源（供 GradientStop 使用） -->
    <Color x:Key="AccentColor">#4C7CFF</Color>
    <Color x:Key="AccentGradientEndColor">#6E96FF</Color>
    <Color x:Key="CurrentCardBgColor">#EEF3FF</Color>
    <Color x:Key="PanelInnerBgColor">#FBFCFE</Color>

    <SolidColorBrush x:Key="PanelBackground" Color="#FBFCFE" Opacity="0.95"/>
    <SolidColorBrush x:Key="PanelBorder" Color="#E5E8EE"/>
    <SolidColorBrush x:Key="PanelInnerBg" Color="#FBFCFE"/>

    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#1B2333"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7488"/>
    <SolidColorBrush x:Key="TextTertiaryBrush"  Color="#A8B0C2"/>
    <SolidColorBrush x:Key="TextOnAccentBrush"  Color="#FFFFFF"/>

    <SolidColorBrush x:Key="AccentBrush"      Color="#4C7CFF"/>
    <SolidColorBrush x:Key="AccentSoftBrush"  Color="#E8EFFD"/>
    <SolidColorBrush x:Key="AccentGradientEnd" Color="#6E96FF"/>

    <SolidColorBrush x:Key="DangerBrush"     Color="#E55060"/>
    <SolidColorBrush x:Key="DangerSoftBrush" Color="#FCE7E9"/>
    <SolidColorBrush x:Key="DoneBrush"       Color="#9AA3B2"/>

    <SolidColorBrush x:Key="TriggerBarBrush"     Color="#C2C9D6"/>
    <SolidColorBrush x:Key="TriggerBarHotBrush"  Color="#4C7CFF"/>
    <SolidColorBrush x:Key="CurrentCardBg"        Color="#EEF3FF"/>
    <SolidColorBrush x:Key="CurrentCardBorder"   Color="#4C7CFF"/>
    <SolidColorBrush x:Key="CurrentCardBgEnd"   Color="#FBFCFE"/>

    <SolidColorBrush x:Key="ItemHoverBrush"   Color="#F1F4F9"/>
    <SolidColorBrush x:Key="ItemActiveBrush"  Color="#E8EFFD"/>

    <SolidColorBrush x:Key="InputBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputBorder"    Color="#E1E6EE"/>
    <SolidColorBrush x:Key="InputFocusGlow"  Color="#4C7CFF"/>

    <SolidColorBrush x:Key="DividerBrush"   Color="#EAEEF4"/>
    <SolidColorBrush x:Key="TopbarBg"        Color="#F4F6FB"/>

    <SolidColorBrush x:Key="WindowDim" Color="#000000" Opacity="0.0"/>
</ResourceDictionary>