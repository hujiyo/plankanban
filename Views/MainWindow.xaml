<Window x:Class="PlanKanban.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PlanKanban.ViewModels"
        Title="PlanKanban"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        UseLayoutRounding="True"
        SizeToContent="Manual"
        WindowStartupLocation="Manual"
        BorderThickness="0"
        Focusable="False"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto">

    <Window.Resources>
        <Style x:Key="RowTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDone}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource DoneBrush}"/>
                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <!-- 主面板 -->
        <Border x:Name="Panel"
                CornerRadius="14"
                BorderThickness="1"
                BorderBrush="{DynamicResource PanelBorder}"
                Background="{DynamicResource PanelBackground}"
                ClipToBounds="True">
            <Border.RenderTransform>
                <TranslateTransform x:Name="PanelTransform" X="0" Y="0"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect x:Name="PanelShadow" Color="Black" Opacity="0.35" BlurRadius="28" ShadowDepth="3" Direction="270"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- 0. 顶部 -->
                    <RowDefinition Height="Auto"/>   <!-- 1. 当前目标卡片 -->
                    <RowDefinition Height="*"/>      <!-- 2. 列表 -->
                    <RowDefinition Height="Auto"/>   <!-- 3. 输入区 -->
                    <RowDefinition Height="Auto"/>   <!-- 4. 底栏 -->
                    <RowDefinition Height="Auto"/>   <!-- 5. 归档折叠区 -->
                </Grid.RowDefinitions>

                <!-- 1. 顶部品牌区 -->
                <Grid Grid.Row="0" Background="{DynamicResource TopbarBg}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="18,14,12,14">
                        <Border Width="22" Height="22" CornerRadius="7" Margin="0,0,11,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="{DynamicResource AccentColor}"/>
                                    <GradientStop Offset="1" Color="{DynamicResource AccentGradientEndColor}"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="K" Foreground="White" FontWeight="SemiBold" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Plan Kanban" FontWeight="SemiBold" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,2,0"/>
                        <TextBlock Text="·" VerticalAlignment="Center" Margin="6,0,6,0"
                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                        <TextBlock Text="极简看板" FontSize="11" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Button x:Name="CollapseBtn" Style="{StaticResource IconButtonStyle}" ToolTip="收起"
                                Click="CollapseBtn_Click">
                            <Path Style="{StaticResource IconGlyphInButton}" Data="{StaticResource IconCollapse}"/>
                        </Button>
                        <Button x:Name="SettingsBtn" Style="{StaticResource IconButtonStyle}" ToolTip="设置"
                                Click="SettingsBtn_Click">
                            <Path Style="{StaticResource IconGlyphInButton}" Data="{StaticResource IconGear}"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- 2. 当前目标卡片 -->
                <Border x:Name="CurrentCard" Grid.Row="1" Margin="18,16,18,4"
                        CornerRadius="12" Padding="18,16"
                        BorderThickness="1.5" BorderBrush="{DynamicResource CurrentCardBorder}"
                        Visibility="{Binding HasCurrentGoal, Converter={x:Static vm:BooleanToVisibilityConverter.Instance}}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="{DynamicResource CurrentCardBgColor}"/>
                            <GradientStop Offset="1" Color="{DynamicResource PanelInnerBgColor}"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid DataContext="{Binding CurrentGoal}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="6" Height="6" CornerRadius="3" Background="{DynamicResource AccentBrush}"
                                    Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock Text="当前目标" FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Text="{Binding Title}" TextWrapping="Wrap"
                                   FontSize="17" FontWeight="SemiBold" LineHeight="24"
                                   Style="{StaticResource RowTextStyle}"/>
                    </Grid>
                </Border>

                <!-- 2. 列表 -->
                <ScrollViewer Grid.Row="2" Margin="10,10,10,8"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              PreviewMouseWheel="List_PreviewMouseWheel">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Style.Resources>
                                <Style TargetType="ScrollBar">
                                    <Setter Property="Width" Value="6"/>
                                </Style>
                            </Style.Resources>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl x:Name="GoalList" ItemsSource="{Binding Goals}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="row" Background="Transparent"
                                        CornerRadius="9" Margin="2,1.5" Padding="10,9"
                                        MouseLeftButtonDown="GoalRow_MouseDown"
                                        MouseEnter="GoalRow_MouseEnter"
                                        MouseLeave="GoalRow_MouseLeave" Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 勾选框 -->
                                        <CheckBox Grid.Column="0" VerticalAlignment="Top" Margin="0,2,0,0"
                                                  IsChecked="{Binding IsDone, Mode=TwoWay}"
                                                  Click="GoalCheck_Click"/>

                                        <!-- 文本 / 编辑框 -->
                                        <Grid Grid.Column="1" Margin="10,0,8,0">
                                            <TextBlock VerticalAlignment="Center" TextWrapping="Wrap"
                                                       Text="{Binding Title}" FontSize="13.5" LineHeight="20">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource RowTextStyle}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBox VerticalAlignment="Top" Margin="0,-3,0,0"
                                                     Style="{StaticResource InputTextBox}"
                                                     Loaded="EditBox_Loaded"
                                                     LostFocus="EditBox_LostFocus"
                                                     KeyDown="EditBox_KeyDown">
                                                <TextBox.Text>
                                                    <Binding Path="Title" Mode="TwoWay" UpdateSourceTrigger="Explicit"/>
                                                </TextBox.Text>
                                                <TextBox.Visibility>
                                                    <Binding Path="IsEditing" Converter="{x:Static vm:BooleanToVisibilityConverter.Instance}"/>
                                                </TextBox.Visibility>
                                            </TextBox>
                                        </Grid>

                                        <!-- 操作按钮 -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top"
                                                    Visibility="{Binding IsEditing, Converter={x:Static vm:BooleanToVisibilityConverter.Instance}, ConverterParameter=Invert}">
                                            <Button Style="{StaticResource IconButtonStyle}" ToolTip="上移"
                                                    Click="MoveUpBtn_Click" Tag="{Binding}">
                                                <Path Style="{StaticResource IconGlyphInButton}" Data="{StaticResource IconArrowUp}"/>
                                            </Button>
                                            <Button Style="{StaticResource IconButtonStyle}" ToolTip="下移"
                                                    Click="MoveDownBtn_Click" Tag="{Binding}">
                                                <Path Style="{StaticResource IconGlyphInButton}" Data="{StaticResource IconArrowDown}"/>
                                            </Button>
                                            <Button Style="{StaticResource IconButtonStyle}" ToolTip="重命名"
                                                    Click="EditBtn_Click" Tag="{Binding}">
                                                <Path Style="{StaticResource IconGlyphInButton}" Data="{StaticResource IconEdit}"/>
                                            </Button>
                                            <Button Style="{StaticResource DangerIconButtonStyle}" ToolTip="删除"
                                                    Click="DeleteBtn_Click" Tag="{Binding}">
                                                <Path Style="{StaticResource IconGlyphInButton}" Data="{StaticResource IconTrash}"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <DataTemplate.Triggers>
                                    <Trigger SourceName="row" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="row" Property="Background" Value="{DynamicResource ItemHoverBrush}"/>
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 3. 输入区（放底部，方便快速追加） -->
                <Grid Grid.Row="3" Margin="18,4,18,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="InputBox" Style="{StaticResource InputTextBox}"
                             Text="{Binding NewGoalText, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="InputBox_KeyDown"
                             ToolTip="回车追加到列表末尾，Shift+回车插入到顶部"/>
                    <Button Grid.Column="1" Content="添加" Style="{StaticResource AccentButtonStyle}" Margin="8,0,0,0"
                            Click="AddBtn_Click" FontWeight="SemiBold"/>
                </Grid>

                <!-- 4. 底栏 -->
                <Border Grid.Row="4" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource DividerBrush}"
                        Background="{DynamicResource TopbarBg}">
                    <Grid Margin="18,10,18,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CounterText" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11.5"/>
                        <Button x:Name="HistoryToggleBtn" Grid.Column="1"
                                Style="{StaticResource GhostButtonStyle}" Padding="10,5" Margin="0,0,4,0"
                                Click="HistoryToggle_Click" ToolTip="查看/恢复已完成归档">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="HistoryCountText" Text="归档" VerticalAlignment="Center"/>
                                <Path x:Name="HistoryChevron" Style="{StaticResource IconGlyph}"
                                      Data="{StaticResource IconChevronDown}" Width="9" Height="9"
                                      Margin="6,0,0,0" VerticalAlignment="Center"
                                      StrokeThickness="1.6"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Content="归档已完成" Style="{StaticResource GhostButtonStyle}"
                                Command="{Binding ArchiveCompletedCommand}" Padding="10,5" ToolTip="归档所有勾选项，并固化完成时间戳"/>
                    </Grid>
                </Border>

                <!-- 6. 归档折叠区 -->
                <Border x:Name="HistoryPanel" Grid.Row="5" Height="0" ClipToBounds="True"
                        Background="{DynamicResource PanelInnerBg}">
                    <StackPanel Margin="18,12,18,14" MaxHeight="280">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="已完成归档" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="全部清空" Style="{StaticResource GhostButtonStyle}"
                                    Command="{Binding ClearArchiveCommand}" Padding="8,4" FontSize="11"/>
                        </Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="220">
                            <ItemsControl ItemsSource="{Binding Archive}" Margin="0,0,0,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource ItemHoverBrush}" CornerRadius="7"
                                                Padding="10,7" Margin="0,1.5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" TextWrapping="Wrap"
                                                               FontSize="12.5" Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextDecorations="Strikethrough"/>
                                                    <TextBlock Text="{Binding ArchivedAtText}" FontSize="10"
                                                               Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="恢复" Style="{StaticResource GhostButtonStyle}"
                                                        Padding="8,3" FontSize="11" Margin="8,0,0,0"
                                                        Command="{Binding DataContext.RestoreFromArchiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock x:Name="HistoryEmptyText" Text="暂无归档" FontSize="11"
                                   Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 触发条 -->
        <Border x:Name="TriggerBar" Background="{DynamicResource TriggerBarBrush}"
                Opacity="0.45" CornerRadius="3"
                MouseEnter="TriggerBar_MouseEnter"
                MouseLeave="TriggerBar_MouseLeave"
                MouseLeftButtonUp="TriggerBar_Click"/>
    </Grid>
</Window>