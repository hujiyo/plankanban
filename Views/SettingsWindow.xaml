<Window x:Class="PlanKanban.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:PlanKanban.Models"
        Title="Plan Kanban 设置"
        Width="440"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PanelBackground}"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="True"
        Topmost="True"
        FontFamily="Segoe UI Variable, Segoe UI, Microsoft YaHei UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock Text="贴靠边缘" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <RadioButton x:Name="EdgeLeft" Content="左边缘" Margin="0,0,16,0"/>
                <RadioButton x:Name="EdgeRight" Content="右边缘" Margin="0,0,16,0"/>
                <RadioButton x:Name="EdgeTop" Content="上边缘"/>
            </StackPanel>

            <TextBlock Text="全局快捷键" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBox x:Name="HotKeyBox" Style="{StaticResource InputTextBox}" Margin="0,0,0,14"
                     IsReadOnly="True" PreviewKeyDown="HotKeyBox_PreviewKeyDown"
                     ToolTip="点击此处后按下需要设置的组合键，例如 Alt+Q"/>

            <TextBlock Text="触发后多久呼出（毫秒）" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Slider x:Name="TriggerDelay" Minimum="0" Maximum="800" Width="260" SmallChange="10" LargeChange="50"
                        TickPlacement="None" ValueChanged="Num_ValueChanged"/>
                <TextBlock x:Name="TriggerDelayVal" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>

            <TextBlock Text="鼠标离开后自动收回延迟（毫秒）" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Slider x:Name="AutoHideDelay" Minimum="400" Maximum="6000" Width="260" SmallChange="50" LargeChange="200"
                        TickPlacement="None" ValueChanged="Num_ValueChanged"/>
                <TextBlock x:Name="AutoHideVal" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>

            <TextBlock Text="面板宽度（像素）" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Slider x:Name="PanelWidth" Minimum="260" Maximum="460" Width="260" SmallChange="10" LargeChange="20"
                        TickPlacement="None" ValueChanged="Num_ValueChanged"/>
                <TextBlock x:Name="PanelWidthVal" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>

            <TextBlock Text="主题" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <RadioButton x:Name="ThemeSystem" Content="跟随系统" Margin="0,0,12,0"/>
                <RadioButton x:Name="ThemeLight" Content="浅色" Margin="0,0,12,0"/>
                <RadioButton x:Name="ThemeDark" Content="深色"/>
            </StackPanel>

            <TextBlock Text="触发显示器" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <ComboBox x:Name="MonitorCombo" Style="{StaticResource InputComboBox}" Margin="0,0,0,14" Width="280" HorizontalAlignment="Left"
                      SelectionChanged="MonitorCombo_SelectionChanged"/>

            <CheckBox x:Name="AutoStartBox" Content="开机自启动" Margin="0,0,0,16"
                      Checked="AutoStartBox_Changed" Unchecked="AutoStartBox_Changed"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="应用" Style="{StaticResource AccentButtonStyle}" Padding="16,6" Margin="0,0,8,0" Click="Apply_Click"/>
                <Button Content="关闭" Style="{StaticResource GhostButtonStyle}" Padding="16,6" Click="Close_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>